{
  "name": "chatboot-alojamiento",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"vite\" \"npm run dev --prefix server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:test": "concurrently -n client,server -c cyan,green \"vite\" \"SIMULATOR_MODE=true npm run dev --prefix server\"",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/src/**/*.ts\"",
    "lint": "eslint .",
    "test": "npm run test:server && npm run test:client",
    "test:server": "npm run test --prefix server",
    "test:client": "vitest run --config vitest.config.frontend.ts",
    "test:load": "tsx server/src/__tests__/load/api.load.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{js,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "i18next": "^25.10.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.6.0",
    "react-router-dom": "^7.1.0",
    "react-virtuoso": "^4.18.3",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
