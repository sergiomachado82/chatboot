# ============================================
# Chatboot - Variables de entorno PRODUCCION
# ============================================
# Copia este archivo como .env.production y completa los valores

# --- Base de datos ---
POSTGRES_USER=chatboot
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=chatboot
# DATABASE_URL se construye automaticamente en docker-compose.prod.yml

# --- Redis ---
# REDIS_URL se construye automaticamente en docker-compose.prod.yml

# --- Server ---
PORT=5050
NODE_ENV=production

# --- JWT (generar con: openssl rand -hex 32) ---
JWT_SECRET=CAMBIAR_POR_SECRET_SEGURO_DE_64_CARACTERES
JWT_EXPIRY=24h

# --- WhatsApp Business API ---
WA_PHONE_NUMBER_ID=tu_phone_number_id
WA_ACCESS_TOKEN=tu_access_token
WA_VERIFY_TOKEN=chatboot-verify-token
WA_APP_SECRET=tu_app_secret
WA_API_VERSION=v21.0

# --- Claude AI ---
ANTHROPIC_API_KEY=sk-ant-api03-tu-clave-aqui

# Modelos (no cambiar salvo que sea necesario)
CLAUDE_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
CLAUDE_RESPONSE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_TIMEOUT_MS=30000

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=tu_sheet_id
GOOGLE_CALENDAR_ID=tu_calendar_id

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS (dominio de produccion) ---
ALLOWED_ORIGINS=https://TUDOMINIO.com

# --- Prisma ---
PRISMA_POOL_SIZE=10

# --- Modo simulador (DEBE ser false en produccion) ---
SIMULATOR_MODE=false

# --- SMTP (Gmail) - Recuperacion de contraseña ---
SMTP_HOST=198.54.114.136
SMTP_PORT=465
SMTP_USER=info@lasgrutasdepartamentos.com
SMTP_PASS=tu-contraseña-smtp
FRONTEND_URL=https://TUDOMINIO.com

# --- IMAP (Email auto-responder) ---
# Si IMAP_HOST/USER/PASS estan vacios, usa los valores de SMTP como fallback
IMAP_HOST=198.54.114.136
IMAP_PORT=993
IMAP_USER=info@lasgrutasdepartamentos.com
IMAP_PASS=tu-contraseña-imap
EMAIL_POLL_INTERVAL_MS=180000
EMAIL_AUTO_RESPONDER_ENABLED=true

# --- Internal Email Pipe (Postfix -> chatbot auto-responder) ---
# Generar con: openssl rand -hex 24
INTERNAL_EMAIL_KEY=

# --- SSL / Dominio ---
DOMAIN=TUDOMINIO.com
EMAIL=tu-email@ejemplo.com
